# ── Required ──
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
JWT_SECRET=replace-with-a-64-char-random-string

# ── Auth (optional overrides) ──
REACT_NATIVE_RELEASE_LEVEL=stable

# ── Backend ──
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ── Supabase Service Role (server-side, NEVER in app) ──
SUPABASE_SERVICE_KEY=your-service-role-key

# ── PostgreSQL (optional, for full backend) ──
DATABASE_URL=postgresql://app:change-me-in-production@localhost:5432/habit_kingdom
DB_PASSWORD=change-me-in-production

# ── Monitoring ──
SENTRY_DSN=https://key@oXXXX.ingest.sentry.io/XXXXXX
EXPO_PUBLIC_SENTRY_DSN=https://key@oXXXX.ingest.sentry.io/XXXXXX
# PostHog product analytics (optional; leave blank to disable)
EXPO_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── CORS ──
ALLOWED_ORIGINS=https://habitkingdom.app,https://www.habitkingdom.app

# ── Production URL (for manifest routing) ──
PRODUCTION_URL=https://habitkingdom.app

# ── Push Notifications (Expo) ──
# Required for push token registration. Get from https://expo.dev/settings/projects
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id
# Backend API URL for push token registration and sync
EXPO_PUBLIC_API_URL=https://api.habitkingdom.app

# ── Encrypted database backups (scripts/backup.mjs → launchd) ──
# Passphrase for AES-256-CBC encryption of backup files at rest.
# Generate with: openssl rand -base64 32
HK_BACKUP_PASSPHRASE=replace-with-a-strong-random-passphrase
# Directory where encrypted .sql.gz.enc backups are written.
HK_BACKUP_DIR=/Users/openclaw/habit-kingdom/backups
# Number of most-recent backups to retain (older ones are pruned).
HK_BACKUP_RETENTION=7
# ── Supabase (LOCAL DEV) ──
# Run `supabase start` (Docker). Get live values with `supabase status`.
# Local API is on Kong port 54321. These are the local-dev defaults.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoiY2x1c3Rlci1kZXZlbG9wbWVudC1zdXBhYmFzZS1kZW1vIiwiaWF0IjoxNjQxNzY5MjAwLCJleHAiOjE3OTk1MzU2MDB9.VZn_0Ymc6qNJkU1jmeEhZDlJFRNnlBzb_r4hWf4Qw8k
# Local DB (for scripts / psql): postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Field-level encryption at rest (AES-256-GCM) ──
# 32-byte key as 64-char hex (or 44-char base64, or any string → scrypt-derived).
# When unset, encryption runs in NO-OP mode (cleartext) so dev/in-memory works.
# Set in production to encrypt PII columns (push tokens, child profile names) at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HK_FIELD_ENCRYPTION_KEY=replace-with-a-64-char-hex-key-for-field-encryption
